# -----------------------------------------------------------------------------
# LoveCraft / VowCanvas - Example Environment Variables
# Copy this file to .env and replace with your actual values
# -----------------------------------------------------------------------------

# --- Frontend (Vite) ---
# The base URL where the backend API is hosted.
VITE_API_BASE_URL=http://localhost:8081

# (Optional) Future additions for frontend
# VITE_ANALYTICS_KEY=
# VITE_CAPTCHA_SITE_KEY=

# --- Backend (Spring Boot) ---
# The active Spring profile (e.g. dev, prod)
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8081

# App configuration
APP_RATE_LIMIT_MAX_REQUESTS=60
APP_RATE_LIMIT_WINDOW_MS=60000
APP_IMAGE_CACHE_MAX_ENTRIES=100

# (Optional) Future Database / Secrets
# JWT_SECRET=
# DATABASE_URL=
# DATABASE_USERNAME=
# DATABASE_PASSWORD=
# EXTERNAL_STORAGE_API_KEY=
